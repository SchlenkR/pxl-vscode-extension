{
  "name": "pxl-clock",
  "displayName": "PXL Clock",
  "description": "Develop and preview pixograms for the PXL Clock directly in VS Code",
  "version": "1.0.8",
  "publisher": "pxlclock",
  "icon": "media/logo.png",
  "homepage": "https://www.pxlclock.com/?ref=RONALD",
  "repository": {
    "type": "git",
    "url": "https://github.com/SchlenkR/pxl-vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "pxl",
    "pixel",
    "led",
    "clock",
    "simulator"
  ],
  "extensionDependencies": [
    "ms-dotnettools.csharp"
  ],
  "activationEvents": [
    "onWebviewPanel:pxl.simulatorCanvas"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pxl.openSimulator",
        "title": "PXL Clock: Open Simulator",
        "icon": "$(preview)"
      },
      {
        "command": "pxl.runScript",
        "title": "PXL Clock: Run Current Script",
        "icon": "$(play)"
      },
      {
        "command": "pxl.stopScript",
        "title": "PXL Clock: Stop Script",
        "icon": "$(debug-stop)"
      },
      {
        "command": "pxl.restartScript",
        "title": "PXL Clock: Restart Script",
        "icon": "$(debug-restart)"
      },
      {
        "command": "pxl.refreshFiles",
        "title": "PXL Clock: Refresh Files",
        "icon": "$(refresh)"
      },
      {
        "command": "pxl.refreshStatus",
        "title": "PXL Clock: Refresh Status",
        "icon": "$(refresh)"
      },
      {
        "command": "pxl.showLog",
        "title": "PXL Clock: Show Log",
        "icon": "$(output)"
      },
      {
        "command": "pxl.openSimulatorToSide",
        "title": "PXL Clock: Open Simulator to Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "pxl.publishPixogram",
        "title": "PXL Clock: Publish Pixogram",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "pxl.publishFromTree",
        "title": "Publish to Clock",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "pxl.initDemos",
        "title": "PXL Clock: Get Example Pixograms"
      },
      {
        "command": "pxl.openFile",
        "title": "PXL Clock: Open File"
      },
      {
        "command": "pxl.runFromTree",
        "title": "Run Pixogram",
        "icon": "$(play)"
      },
      {
        "command": "pxl.newPixogram",
        "title": "New Pixogram",
        "icon": "$(new-file)"
      },
      {
        "command": "pxl.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "pxl.revealInExplorer",
        "title": "Reveal in Explorer View",
        "icon": "$(folder-opened)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pxl-explorer",
          "title": "PXL Clock",
          "icon": "media/logo_monochrome.svg"
        }
      ]
    },
    "views": {
      "pxl-explorer": [
        {
          "id": "pxlSimulatorStatus",
          "type": "webview",
          "name": "Simulator",
          "icon": "$(server-process)"
        },
        {
          "id": "pxlSimulatorView",
          "type": "webview",
          "name": "Preview",
          "icon": "$(preview)"
        },
        {
          "id": "pxlFiles",
          "name": "Pixograms",
          "icon": "$(file-code)"
        }
      ]
    },
    "configuration": {
      "title": "PXL Clock",
      "properties": {
        "pxl.simulatorPortRange": {
          "type": "string",
          "default": "5010-5099",
          "description": "Port range for the PXL Simulator Host (e.g. 5010-5099). A free port is chosen automatically from this range."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .cs",
          "command": "pxl.runScript",
          "group": "navigation"
        },
        {
          "when": "resourceExtname == .cs",
          "command": "pxl.publishPixogram",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "pxl.refreshStatus",
          "when": "view == pxlSimulatorStatus",
          "group": "navigation"
        },
        {
          "command": "pxl.showLog",
          "when": "view == pxlSimulatorStatus",
          "group": "navigation"
        },
        {
          "command": "pxl.openSimulator",
          "when": "view == pxlSimulatorStatus",
          "group": "navigation"
        },
        {
          "command": "pxl.refreshFiles",
          "when": "view == pxlFiles",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "pxl.runFromTree",
          "when": "view == pxlFiles && viewItem == csFile",
          "group": "inline"
        },
        {
          "command": "pxl.publishFromTree",
          "when": "view == pxlFiles && viewItem == csFile",
          "group": "inline"
        },
        {
          "command": "pxl.newPixogram",
          "when": "view == pxlFiles && viewItem == directory",
          "group": "1_new@1"
        },
        {
          "command": "pxl.newFolder",
          "when": "view == pxlFiles && viewItem == directory",
          "group": "1_new@2"
        },
        {
          "command": "pxl.runFromTree",
          "when": "view == pxlFiles && viewItem == csFile",
          "group": "2_actions@1"
        },
        {
          "command": "pxl.publishFromTree",
          "when": "view == pxlFiles && viewItem == csFile",
          "group": "2_actions@2"
        },
        {
          "command": "pxl.revealInExplorer",
          "when": "view == pxlFiles",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        { "command": "pxl.openSimulatorToSide", "when": "false" },
        { "command": "pxl.openFile", "when": "false" },
        { "command": "pxl.refreshFiles", "when": "false" },
        { "command": "pxl.refreshStatus", "when": "false" },
        { "command": "pxl.restartScript", "when": "false" },
        { "command": "pxl.runFromTree", "when": "false" },
        { "command": "pxl.publishFromTree", "when": "false" },
        { "command": "pxl.publishPixogram", "when": "false" },
        { "command": "pxl.newPixogram", "when": "false" },
        { "command": "pxl.newFolder", "when": "false" },
        { "command": "pxl.revealInExplorer", "when": "false" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js --production",
    "build:simulator": "bash build-simulator.sh --current",
    "build:simulator:all": "bash build-simulator.sh",
    "devbuild": "bash build-simulator.sh --current && node esbuild.js --production",
    "start:vscodeDevInstance": "code --extensionDevelopmentPath=${PWD}",
    "watch": "node esbuild.js --watch",
    "package": "bash build-simulator.sh --current && npx @vscode/vsce package",
    "package:all": "bash build-simulator.sh && npx @vscode/vsce package",
    "publish": "bash build-simulator.sh && npx @vscode/vsce publish ${AZURE_DEVOPS_VSCE_PXLCLOCK_PAT:+--pat $AZURE_DEVOPS_VSCE_PXLCLOCK_PAT}"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.24.0",
    "pxl-device-view": "file:../pxl-software/src/pxl-device-view",
    "pxl-receiver-canvas": "file:../pxl-software/src/pxl-receiver-canvas",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.0",
    "ws": "^8.19.0"
  }
}
